{
  "name": "sage-and-oat",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack --no-lint",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:unit": "jest",
    "test:ci": "npm run typecheck && npm run test:unit && npm run test",
    "lighthouse:prod": "lighthouse https://sageandoat.com --output=html --output-path=./lighthouse-report.html --only-categories=performance,accessibility --preset=desktop",
    "lighthouse:home": "lighthouse http://localhost:3000 --output=html --output-path=./lighthouse-home.html --only-categories=performance,accessibility --preset=desktop",
    "lighthouse:ci": "lighthouse http://localhost:3000 --output=json --output-path=./lighthouse-ci.json --only-categories=performance,accessibility --preset=desktop --chrome-flags='--headless'",
    "a11y:dev": "echo 'Run axe DevTools extension or use: npm install -g axe-core && axe http://localhost:3000'",
    "sync:full": "curl -X POST http://localhost:3000/api/sync/catalog -H \"Content-Type: application/json\" -d \"{\\\"full\\\":true}\"",
    "sync:delta": "curl -X POST http://localhost:3000/api/sync/catalog -H \"Content-Type: application/json\" -d \"{}\"",
    "ci": "npm run lint && npm run typecheck && npm run test:ci",
    "prepare": "husky"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.81.1",
    "@types/lru-cache": "^7.10.10",
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^1.2.0",
    "algoliasearch": "^5.44.0",
    "cloudinary": "^2.8.0",
    "clsx": "^2.1.1",
    "critters": "^0.0.25",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "lru-cache": "^11.2.2",
    "lucide-react": "^0.554.0",
    "next": "15.5.6",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-instantsearch": "^7.19.0",
    "schema-dts": "^1.1.5",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.1.12",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.56.1",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.46.4",
    "@typescript-eslint/parser": "^8.43.0",
    "autoprefixer": "^10.4.22",
    "eslint": "^9",
    "eslint-config-next": "15.5.6",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-sonarjs": "^3.0.5",
    "eslint-plugin-unused-imports": "^4.3.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "lint-staged": "^16.2.6",
    "postcss": "^8.4.0",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "tailwindcss": "^3.4.18",
    "ts-jest": "^29.4.5",
    "typescript": "^5"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
